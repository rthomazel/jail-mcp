set -euo pipefail
shopt -s globstar
trap 'err $LINENO' ERR

err() {
  echo "error: line $1" >&2
}

cmd="${1:-help}"

    # AGENTS: run commands directly, you cant execute this file
case "$cmd" in
  lint)
    golangci-lint run ./...
    ;;
  server)
    # TODO: add to container dependencies, agents cant see go tools under $HOME/go
    "${GOPATH:-$HOME/go}/bin/godotenv" -f .env go run main.go
    ;;
  build)
    go build -o bin/server main.go
    ;;
  help|*)
    echo "Usage: ./run <command>"
    echo ""
    echo "Commands:"
    echo "  lint   golangci-lint run ./..."
    echo "  server    godotenv -f .env go run main.go"
    ;;
esac
