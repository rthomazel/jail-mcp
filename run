set -euo pipefail
shopt -s globstar
trap 'echo fatal: $0:$LINENO >&2' ERR

# AGENTS: run commands directly, you cannot execute this file. if making changes to this file, run chmod u+x on it.
cmd="${1:-help}"

IMAGE="ghcr.io/rthomazel/jail-mcp"

case "$cmd" in
# -- run golangci-lint
lint)
  golangci-lint run ./...
  ;;
# -- start the server with godotenv
dev)
  "${GOPATH:-$HOME/go}/bin/godotenv" -f .env go run main.go
  ;;
# -- run tests
test)
  "${GOPATH:-$HOME/go}/bin/godotenv" -f .env go test -race ./...
  ;;
# -- run gofumpt formatter
format)
  gofumpt -l -w .
  ;;
# -- build local binary to bin/server
build)
  go build -o bin/server main.go
  ;;
# -- bring the http server container UP
up)
  docker compose -f docker-compose-http.yml up -d
  ;;
# -- build versioned docker image tagged latest
docker-build)
  version="$(git describe --tags --abbrev=0)"
  commit="$(git rev-parse --short HEAD)"
  date="$(date +%Y.%m.%d.%H:%M)"

  docker compose -f docker-compose.yml build --build-arg VERSION="${version}_${commit}_$date"
  ;;
# -- print a prompt for updating the changelog
prompt:changelog)
  cat << 'EOF'
Update CHANGELOG.md for a new release.

- New version: {version} # operator: add value here
- PR URL: {pr_url} # operator: add value here
- Base branch: main

Steps:

1. Run `git log main..HEAD --format="%h %s"` to get all commits since main.
2. Read CHANGELOG.md to match the existing format.
3. Group commits by their conventional commit type (feat, fix, refactor, build, docs, misc, etc.) — one ### block per type.
4. For each commit, write a bullet in the format:
   - [`{hash}`](`{repo_url}/commit/{hash}`) **(scope)** message — short technical description expanding on what changed and why.
5. Omit the scope prefix if the commit has none.
6. Prepend the new entry to the top of the changelog, below the # CHANGELOG heading, without modifying any existing entries.

The entry heading should follow the pattern of existing entries: ## [{version}]({pr_url}) {type}: {short title}.
EOF
  ;;
help | *)
  echo "Usage: ./run <command>"
  echo ""
  echo "Commands:"
  awk '/^# -- /{desc=substr($0, index($0,"-- ")+3)} /\)$/ && desc{cmd=$0; gsub(/[[:space:]()|*]/, "", cmd); printf "  %-20s %s\n", cmd, desc; desc=""}' "$0"
  ;;
esac
