set -euo pipefail
shopt -s globstar
trap 'err $LINENO' ERR

err() {
  echo "error: line $1" >&2
}

# AGENTS: run commands directly, you cannot execute this file.
# AGENTS: if making changes to this file, run chmod u+x on it.
cmd="${1:-help}"

case "$cmd" in
  # -- run golangci-lint
  lint)
    golangci-lint run ./...
    ;;
  # -- start the server with godotenv
  dev)
    # TODO: add to container dependencies, agents cant see go tools under $HOME/go
    "${GOPATH:-$HOME/go}/bin/godotenv" -f .env go run main.go
    ;;
  # -- build local binary to bin/server
  build)
    go build -o bin/server main.go
    ;;
  # -- build docker image tagged jail-mcp with current commit as version
  docker-build)
    docker compose -f docker-compose.yml build --build-arg VERSION="$(git rev-parse --short HEAD)"
    ;;
  help|*)
    echo "Usage: ./run <command>"
    echo ""
    echo "Commands:"
    awk '/^  # -- /{desc=substr($0, index($0,"-- ")+3)} /\)$/ && desc{cmd=$0; gsub(/[[:space:]()|*]/, "", cmd); printf "  %-20s %s\n", cmd, desc; desc=""}' "$0"
    ;;
esac
