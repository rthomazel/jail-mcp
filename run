set -euo pipefail
shopt -s globstar
trap 'err $LINENO' ERR

cmd="${1:-help}"

case "$cmd" in
  lint)
    golangci-lint run ./...
    ;;
  server)
    godotenv -f .env go run main.go
    ;;
  help|*)
    echo "Usage: ./run <command>"
    echo ""
    echo "Commands:"
    echo "  lint   golangci-lint run ./..."
    echo "  server    godotenv -f .env go run main.go"
    ;;
esac
