#!/bin/sh

if [ "$JAIL_MCP_HTTP" = "true" ] || [ "$JAIL_MCP_TRANSPORT" = "mcpo" ]; then
    echo "INFO: starting jail-mcp with mcpo (OpenAI-compatible HTTP)" >&2
    exec mcpo --port 8001 -- jail-mcp
elif [ "$JAIL_MCP_TRANSPORT" = "mcp-proxy" ]; then
    echo "INFO: starting jail-mcp with mcp-proxy (native MCP/SSE)" >&2
    exec mcp-proxy --pass-environment --host 0.0.0.0 --port 8001 -- jail-mcp
else
    echo "INFO: starting jail-mcp in stdio mode" >&2
    exec jail-mcp
fi
